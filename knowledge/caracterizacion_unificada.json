{
  "foria": [
    {
      "nombre": "Eufórico",
      "descripcion": "Emoción de tono positivo, alegría o satisfacción.",
      "ejemplo": "\"Estoy contento con los resultados\" → eufórico"
    },
    {
      "nombre": "Disfórico",
      "descripcion": "Emoción de tono negativo, malestar o desagrado.",
      "ejemplo": "\"Me preocupa la situación\" → disfórico"
    },
    {
      "nombre": "Afórico",
      "descripcion": "Emoción neutra, sin polaridad positiva ni negativa clara.",
      "ejemplo": "\"Observé los hechos\" → afórico"
    },
    {
      "nombre": "Ambifórico",
      "descripcion": "Emoción con mezcla de tonalidades positiva y negativa.",
      "ejemplo": "\"Estoy feliz pero preocupado\" → ambifórico"
    }
  ],
  "dominancia": [
    {
      "nombre": "Corporal",
      "descripcion": "La emoción se manifiesta principalmente en sensaciones físicas o gestos.",
      "ejemplo": "\"Se le aceleró el corazón\" → corporal"
    },
    {
      "nombre": "Cognoscitiva",
      "descripcion": "La emoción se basa en juicios, evaluaciones o pensamientos.",
      "ejemplo": "\"Considero injusta la decisión\" → cognoscitiva"
    },
    {
      "nombre": "Mixta",
      "descripcion": "La emoción combina indicios corporales y cognitivos.",
      "ejemplo": "\"Temía y estaba nervioso\" → mixta"
    }
  ],
  "intensidad": [
    {
      "nombre": "Alta",
      "descripcion": "Emoción fuertemente expresada o inferible.",
      "ejemplo": "\"Estaba completamente eufórico\" → alta"
    },
    {
      "nombre": "Baja",
      "descripcion": "Emoción leve o sutil.",
      "ejemplo": "\"Sentía un leve nerviosismo\" → baja"
    },
    {
      "nombre": "Neutra/Ambivalente",
      "descripcion": "Emoción sin intensidad clara o con sentimientos contradictorios.",
      "ejemplo": "\"Tenía sentimientos encontrados\" → neutra/ambivalente"
    }
  ]
}
